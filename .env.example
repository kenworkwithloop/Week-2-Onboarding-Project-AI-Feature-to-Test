# Copy to `.env` and fill in (never commit real keys — `.env` is gitignored).
# Required: used to extract intent (city + days) from the user prompt.
OPENAI_API_KEY=

# Optional: OpenAI chat model used for intent extraction (default: gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini

# Optional: port for the Fastify server (default: 3000).
PORT=3000

# Required for the get_stock_data tool (Alpha Vantage GLOBAL_QUOTE endpoint).
# Free-tier keys are rate-limited; get one at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=
