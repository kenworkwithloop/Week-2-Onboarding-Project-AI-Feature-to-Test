{
  "name": "omniplanner-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Weather-aware travel planner: OpenAI intent extraction + Open-Meteo weather tool.",
  "type": "module",
  "bin": {
    "omniplanner": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import tsx src/cli.ts",
    "start": "node dist/cli.js",
    "serve": "node --import tsx src/server.ts",
    "lint:types": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
